{
  "name": "sage-and-spoon",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "recipes:report": "node scripts/report-coverage.mjs",
    "recipes:generate": "node scripts/generate-recipes.mjs",
    "recipes:promote": "node scripts/promote-recipes.mjs",
    "images:fetch": "node scripts/fetch-images.mjs",
    "images:audit": "node scripts/fetch-images.mjs --audit",
    "images:self-host": "node scripts/self-host-images.mjs",
